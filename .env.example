# ================================
# Core (required)
# ================================
MONGODB_URI=
AUTH_SECRET=

# ================================
# Auth providers (optional)
# Fill if you want OAuth login
# ================================
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Useful in production for correct callback URLs
# Example: https://your-domain.com
NEXTAUTH_URL=

# ================================
# AI answers (optional)
# ================================
# Groq (preferred if set, OpenAI-compatible free tier limits may apply)
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile

# xAI / Grok (preferred if both are set)
XAI_API_KEY=
XAI_BASE_URL=https://api.x.ai/v1
XAI_MODEL=grok-4.20-beta-latest-non-reasoning

# OpenAI fallback
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ================================
# Jobs API (optional)
# ================================
RAPID_API_KEY=

# ================================
# App/API URLs (optional)
# ================================
NEXT_PUBLIC_API_BASE_URL=

# ================================
# Not used by current codebase
# Keep empty or remove if not needed
# ================================
NEXT_PUBLIC_TINY_EDITOR_API_KEY=
NEXT_PUBLIC_SERVER_URL=

# Runtime note:
# Do not set NODE_ENV manually on Vercel/Next.js unless you have a specific need.
